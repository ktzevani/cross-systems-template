htmlcov/


# ----------------------------
# CMake build directories
# ----------------------------
build/
build-*/
out/
cmake-build-*/
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
compile_commands.json
CTestTestfile.cmake
Testing/

# CMake user/package files
CMakeUserPresets.json
CMakePackageConfigHelpers.cmake


# ----------------------------
# Conan 2 generated files
# ----------------------------
# If you generate Conan files into build folders, build/ already covers them.
# These are here in case Conan generators are accidentally emitted in-tree.
conanbuild/
conanrun/
generators/
CMakePresets.json.user
conan_toolchain.cmake
conanbuildinfo.*
conaninfo.txt
graph_info.json
conan.lock

# Usually commit conanfile.py / conanfile.txt.
# Usually do NOT commit generated conan.lock unless you intentionally use it
# as a dependency lockfile. For applications, committing it can be valid.


