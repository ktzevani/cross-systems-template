{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "00. Startup: Windows native setup check",
      "type": "shell",
      "command": "echo",
      "args": [
        "Skipping Windows native setup check on this platform."
      ],
      "presentation": {
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "clear": true,
        "showReuseMessage": false
      },
      "runOptions": {
        "runOn": "folderOpen"
      },
      "problemMatcher": [],
      "windows": {
        "type": "process",
        "command": "powershell.exe",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-File",
          "${workspaceFolder}\\scripts\\startup-windows.ps1"
        ],
        "options": {
          "cwd": "${workspaceFolder}"
        }
      }
    },
    {
      "label": "01 Conan: Install linux-gcc-ninja-debug",
      "type": "shell",
      "command": "uv run --active conan install . --profile:host=profiles/linux-gcc-ninja-debug --profile:build=profiles/linux-gcc-ninja-debug --build=missing -of out/conan/linux-gcc-ninja-debug",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "args": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "02 Conan: Install linux-gcc-ninja-release",
      "type": "shell",
      "command": "uv run --active conan install . --profile:host=profiles/linux-gcc-ninja-release --profile:build=profiles/linux-gcc-ninja-release --build=missing -of out/conan/linux-gcc-ninja-release",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "args": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "03. Conan: Install windows-msvc-ninja-debug",
      "type": "shell",
      "command": "uv run --active conan install . --profile:host=profiles/windows-msvc-ninja-debug --profile:build=profiles/windows-msvc-ninja-debug --build=missing -of out/conan/windows-msvc-ninja-debug",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "args": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "04. Conan: Install windows-msvc-ninja-release",
      "type": "shell",
      "command": "uv run --active conan install . --profile:host=profiles/windows-msvc-ninja-release --profile:build=profiles/windows-msvc-ninja-release --build=missing -of out/conan/windows-msvc-ninja-release",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "args": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "05. Conan: Install windows-msvc-msbuild all configs",
      "type": "shell",
      "command": "echo",
      "args": [
        "Skipping Windows MSBuild Conan install on this platform."
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": [],
      "windows": {
        "type": "process",
        "command": "powershell.exe",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-File",
          "${workspaceFolder}\\scripts\\install-conan-windows-msvc-msbuild.ps1"
        ],
        "options": {
          "cwd": "${workspaceFolder}"
        }
      }
    },
    {
      "label": "11 Debug: Prepare linux-gcc-ninja-debug",
      "dependsOrder": "sequence",
      "dependsOn": [
        "01 Conan: Install linux-gcc-ninja-debug",
        "11.1 CMake: Configure linux-gcc-ninja-debug",
        "11.2 CMake: Build linux-gcc-ninja-debug"
      ],
      "problemMatcher": []
    },
    {
      "label": "11.1 CMake: Configure linux-gcc-ninja-debug",
      "type": "shell",
      "command": "cmake --preset linux-gcc-ninja-debug",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "11.2 CMake: Build linux-gcc-ninja-debug",
      "type": "shell",
      "command": "cmake --build --preset linux-gcc-ninja-debug",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "12 Debug: Prepare windows-msvc-ninja-debug",
      "dependsOrder": "sequence",
      "dependsOn": [
        "03. Conan: Install windows-msvc-ninja-debug",
        "12.1 CMake: Configure windows-msvc-ninja-debug",
        "12.2 CMake: Build windows-msvc-ninja-debug"
      ],
      "problemMatcher": []
    },
    {
      "label": "12.1 CMake: Configure windows-msvc-ninja-debug",
      "type": "shell",
      "command": "cmake --preset windows-msvc-ninja-debug",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "12.2 CMake: Build windows-msvc-ninja-debug",
      "type": "shell",
      "command": "cmake --build --preset windows-msvc-ninja-debug",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    }
  ]
}
